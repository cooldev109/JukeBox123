# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jukebox?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Pix Payment Gateway (Mercado Pago example)
PIX_GATEWAY_URL="https://api.mercadopago.com"
PIX_ACCESS_TOKEN="your-pix-access-token"
PIX_WEBHOOK_SECRET="your-webhook-secret"

# Cloud Storage (S3-compatible)
S3_ENDPOINT="https://your-s3-endpoint.com"
S3_BUCKET="jukebox-songs"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_REGION="sa-east-1"

# Admin
ADMIN_BILLING_PASSWORD="change-me"

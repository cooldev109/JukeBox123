# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jukebox?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ============================================
# Pix Payment Gateway
# ============================================
# Provider: "sandbox" (default), "mercadopago", or "efi"
PIX_PROVIDER="sandbox"

# --- Mercado Pago ---
# PIX_PROVIDER="mercadopago"
# PIX_GATEWAY_URL="https://api.mercadopago.com"
# PIX_ACCESS_TOKEN="APP_USR-xxxx-your-mercadopago-access-token"
# PIX_WEBHOOK_SECRET="your-mercadopago-webhook-secret"

# --- EFÍ (Gerencianet) ---
# PIX_PROVIDER="efi"
# EFI_CLIENT_ID="your-efi-client-id"
# EFI_CLIENT_SECRET="your-efi-client-secret"
# EFI_BASE_URL="https://pix.api.efipay.com.br"
# EFI_PIX_KEY="your-registered-pix-key"
# EFI_CERTIFICATE_PATH="/path/to/efi-certificate.pem"
# PIX_WEBHOOK_SECRET="your-efi-webhook-secret"

# ============================================
# Stripe (Stage 2 — Card Payments)
# ============================================
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"
# Frontend needs the publishable key (set in apps/web/.env)
# VITE_STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"

# Cloud Storage (S3-compatible)
S3_ENDPOINT="https://your-s3-endpoint.com"
S3_BUCKET="jukebox-songs"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_REGION="sa-east-1"

# Admin
ADMIN_BILLING_PASSWORD="change-me"

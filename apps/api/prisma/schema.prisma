generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER
// ============================================
enum UserRole {
  ADMIN
  BAR_OWNER
  CUSTOMER
  EMPLOYEE
  AFFILIATE
}

model User {
  id           String    @id @default(uuid())
  email        String?   @unique
  phone        String?   @unique
  name         String
  role         UserRole  @default(CUSTOMER)
  passwordHash String?
  avatar       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isActive     Boolean   @default(true)

  // Google OAuth
  googleId     String?   @unique

  // Stage 2 fields
  regionAccess String?   // For EMPLOYEE: city/state/country they manage
  referralCode String?   @unique // For AFFILIATE: unique referral code

  // Relations
  venues              Venue[]              @relation("VenueOwner")
  queueItems          QueueItem[]
  transactions        Transaction[]
  wallet              Wallet?
  playlists           Playlist[]
  songRequests        SongRequest[]
  commissions         Commission[]         @relation("AffiliateCommissions")
  affiliateReferrals  AffiliateReferral[]
  machineAlertsResolved MachineAlert[]     @relation("AlertResolvedBy")
  specialEventsCreated  SpecialEvent[]     @relation("SpecialEventUser")
  specialEventsApproved SpecialEvent[]     @relation("SpecialEventApprover")
  bannersCreated      Banner[]             @relation("BannerCreator")
  pushSubscriptions   PushSubscription[]
  affiliateSplits     RevenueSplit[]       @relation("AffiliateSplits")
  operatorSplits      RevenueSplit[]       @relation("OperatorSplits")

  @@index([role])
  @@index([email])
  @@index([phone])
  @@index([referralCode])
}

// ============================================
// VENUE (Bar/Club)
// ============================================
enum VenueStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Venue {
  id          String      @id @default(uuid())
  code        String      @unique // Short code for customer entry (e.g. "BAR-CARLOS")
  name        String
  address     String
  city        String
  state       String
  country     String      @default("BR")
  ownerId     String
  timezone    String      @default("America/Sao_Paulo")
  currency    String      @default("BRL")
  settings    Json        @default("{}")
  status      VenueStatus @default(ACTIVE)
  installDate DateTime?
  regionId    String?
  pixKey      String?     // Venue's Pix key (CPF, CNPJ, email, phone, or EVP)
  pixKeyType  String?     // Type: CPF, CNPJ, EMAIL, PHONE, EVP
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  owner              User                @relation("VenueOwner", fields: [ownerId], references: [id])
  region             Region?             @relation(fields: [regionId], references: [id])
  machines           Machine[]
  commissions        Commission[]
  affiliateReferrals AffiliateReferral[]
  productPrices      VenueProductPrice[]
  revenueSplits      RevenueSplit[]

  @@index([ownerId])
  @@index([city, state])
  @@index([status])
  @@index([regionId])
}

// ============================================
// MACHINE (Jukebox Device)
// ============================================
enum MachineStatus {
  ONLINE
  OFFLINE
  ERROR
  ALERT
}

model Machine {
  id               String        @id @default(uuid())
  venueId          String
  name             String
  serialNumber     String        @unique
  status           MachineStatus @default(ONLINE)
  lastHeartbeat    DateTime?
  ipAddress        String?
  offlineSongCache String[]      @default([])
  config           Json          @default("{}")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  venue         Venue          @relation(fields: [venueId], references: [id])
  queueItems    QueueItem[]
  transactions  Transaction[]
  alerts        MachineAlert[]
  specialEvents SpecialEvent[]

  @@index([venueId])
  @@index([status])
  @@index([serialNumber])
}

// ============================================
// CATALOG HIERARCHY: Genre > Artist > Album > Song
// ============================================
model Genre {
  id          String   @id @default(uuid())
  name        String   @unique
  coverArtUrl String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  artists     Artist[]
  regionCatalogs RegionCatalog[]
  createdAt   DateTime @default(now())

  @@index([isActive])
}

model Artist {
  id          String   @id @default(uuid())
  name        String
  genreId     String
  genre       Genre    @relation(fields: [genreId], references: [id])
  coverArtUrl String?
  isActive    Boolean  @default(true)
  albums      Album[]
  createdAt   DateTime @default(now())

  @@unique([name, genreId])
  @@index([genreId])
  @@index([isActive])
}

model Album {
  id          String   @id @default(uuid())
  name        String
  artistId    String
  artist      Artist   @relation(fields: [artistId], references: [id])
  coverArtUrl String?
  year        Int?
  isActive    Boolean  @default(true)
  songs       Song[]
  createdAt   DateTime @default(now())

  @@unique([name, artistId])
  @@index([artistId])
  @@index([isActive])
}

// ============================================
// SONG
// ============================================
enum SongFormat {
  MP3
  MP4
}

model Song {
  id          String     @id @default(uuid())
  title       String
  artist      String
  album       String?
  genre       String
  duration    Int        // seconds
  fileUrl         String
  originalFileUrl String?    // Original source URL (e.g., archive.org) as backup
  videoUrl        String?
  coverArtUrl String?
  metadata    Json       @default("{}")
  fileSize    Int        @default(0) // bytes
  format      SongFormat @default(MP3)
  isActive    Boolean    @default(true)
  playCount   Int        @default(0)
  addedAt     DateTime   @default(now())

  // Catalog hierarchy (optional — backward compatible)
  albumId     String?
  albumRef    Album?     @relation(fields: [albumId], references: [id])
  trackNumber Int?

  // Relations
  queueItems QueueItem[]

  @@index([title, artist])
  @@index([genre])
  @@index([artist])
  @@index([isActive])
  @@index([playCount(sort: Desc)])
  @@index([albumId])
}

// ============================================
// QUEUE
// ============================================
enum QueueItemStatus {
  PENDING
  PLAYING
  PLAYED
  SKIPPED
}

model QueueItem {
  id            String          @id @default(uuid())
  machineId     String
  songId        String
  userId        String
  position      Int
  status        QueueItemStatus @default(PENDING)
  paidAmount    Float           @default(0)
  paymentMethod String          @default("PIX")
  isPriority    Boolean         @default(false)
  createdAt     DateTime        @default(now())
  playedAt      DateTime?

  // Relations
  machine Machine @relation(fields: [machineId], references: [id])
  song    Song    @relation(fields: [songId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([machineId, status])
  @@index([machineId, position])
  @@index([userId])
}

// ============================================
// TRANSACTION
// ============================================
enum TransactionType {
  CREDIT_PURCHASE
  SONG_PAYMENT
  SKIP_QUEUE
  SILENCE
  VOICE_MSG
  REACTION
  PHOTO
  BIRTHDAY_PACK
}

enum PaymentMethod {
  PIX
  WALLET
  CREDIT_CARD
  DEBIT_CARD
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Transaction {
  id               String            @id @default(uuid())
  userId           String
  machineId        String?
  type             TransactionType
  amount           Float
  currency         String            @default("BRL")
  paymentMethod    PaymentMethod
  status           TransactionStatus @default(PENDING)
  pixTransactionId String?
  stripePaymentId  String?           // Stage 2: Stripe payment reference
  idempotencyKey   String?           @unique
  metadata         Json              @default("{}")
  createdAt        DateTime          @default(now())

  // Relations
  user          User           @relation(fields: [userId], references: [id])
  machine       Machine?       @relation(fields: [machineId], references: [id])
  commissions   Commission[]
  revenueSplits RevenueSplit[]

  @@index([userId])
  @@index([machineId])
  @@index([status])
  @@index([type])
  @@index([createdAt(sort: Desc)])
}

// ============================================
// WALLET
// ============================================
model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Float    @default(0)
  currency  String   @default("BRL")
  lastTopUp DateTime?
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ============================================
// PLAYLIST (Customer Saved Playlists)
// ============================================
model Playlist {
  id        String   @id @default(uuid())
  userId    String
  name      String
  songIds   String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ============================================
// SONG REQUEST (Customer requests new songs)
// ============================================
model SongRequest {
  id        String   @id @default(uuid())
  userId    String
  title     String
  artist    String
  notes     String?
  isHandled Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([isHandled])
  @@index([createdAt(sort: Desc)])
}

// ============================================
// GLOBAL CONFIG
// ============================================
model GlobalConfig {
  id    String @id @default(uuid())
  key   String @unique
  value Json

  @@index([key])
}

// ============================================
// STAGE 2: COMMISSION
// ============================================
enum CommissionType {
  SALE
  VENUE_REFERRAL
}

enum CommissionStatus {
  PENDING
  PAID
}

model Commission {
  id                 String           @id @default(uuid())
  affiliateId        String
  transactionId      String
  venueId            String
  percentage         Float
  amount             Float
  type               CommissionType
  status             CommissionStatus @default(PENDING)
  paidAt             DateTime?
  referralDuration   Int?             // months
  referralPercentage Float?
  createdAt          DateTime         @default(now())

  // Relations
  affiliate   User        @relation("AffiliateCommissions", fields: [affiliateId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id])
  venue       Venue       @relation(fields: [venueId], references: [id])

  @@index([affiliateId])
  @@index([transactionId])
  @@index([venueId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

// ============================================
// STAGE 2: AFFILIATE REFERRAL
// ============================================
model AffiliateReferral {
  id               String   @id @default(uuid())
  affiliateId      String
  venueId          String
  referralCode     String
  commissionPercent Float    // 50-100%
  durationMonths   Int      // 1-6
  startDate        DateTime @default(now())
  endDate          DateTime
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  // Relations
  affiliate User  @relation(fields: [affiliateId], references: [id])
  venue     Venue @relation(fields: [venueId], references: [id])

  @@index([affiliateId])
  @@index([venueId])
  @@index([referralCode])
  @@index([isActive])
}

// ============================================
// STAGE 2: MACHINE ALERT
// ============================================
enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertType {
  OFFLINE
  AUDIO_FAIL
  PAYMENT_ERROR
  OWNER_INACTIVE
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  DASHBOARD
}

model MachineAlert {
  id           String              @id @default(uuid())
  machineId    String
  type         AlertType
  message      String
  severity     AlertSeverity       @default(MEDIUM)
  isResolved   Boolean             @default(false)
  resolvedAt   DateTime?
  resolvedById String?
  notifiedVia  NotificationChannel @default(DASHBOARD)
  createdAt    DateTime            @default(now())

  // Relations
  machine    Machine @relation(fields: [machineId], references: [id])
  resolvedBy User?   @relation("AlertResolvedBy", fields: [resolvedById], references: [id])

  @@index([machineId])
  @@index([isResolved])
  @@index([severity])
  @@index([createdAt(sort: Desc)])
}

// ============================================
// STAGE 2: SPECIAL EVENT
// ============================================
enum SpecialEventType {
  SILENCE
  VOICE_MESSAGE
  TEXT_MESSAGE
  PHOTO
  REACTION
  BIRTHDAY
}

enum SpecialEventStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PLAYED
}

model SpecialEvent {
  id           String             @id @default(uuid())
  machineId    String
  userId       String
  type         SpecialEventType
  content      String?            // text content or media URL
  duration     Int?               // seconds
  amount       Float              @default(0)
  status       SpecialEventStatus @default(PENDING_APPROVAL)
  approvedById String?
  createdAt    DateTime           @default(now())

  // Relations
  machine    Machine @relation(fields: [machineId], references: [id])
  user       User    @relation("SpecialEventUser", fields: [userId], references: [id])
  approvedBy User?   @relation("SpecialEventApprover", fields: [approvedById], references: [id])

  @@index([machineId])
  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt(sort: Desc)])
}

// ============================================
// STAGE 2: PUSH SUBSCRIPTION
// ============================================
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// STAGE 2: BANNER
// ============================================
enum BannerTargetRole {
  AFFILIATE
  CUSTOMER
  ALL
}

model Banner {
  id          String           @id @default(uuid())
  targetRole  BannerTargetRole @default(ALL)
  imageUrl    String?
  linkUrl     String?
  message     String
  isActive    Boolean          @default(true)
  startDate   DateTime         @default(now())
  endDate     DateTime?
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  createdBy User @relation("BannerCreator", fields: [createdById], references: [id])

  @@index([targetRole])
  @@index([isActive])
  @@index([startDate, endDate])
}

// ============================================
// STAGE 3: PRODUCT (Flexible Pricing)
// ============================================
model Product {
  id          String   @id @default(uuid())
  code        String   @unique // e.g. "SONG", "PRIORITY_SONG", "SILENCE_15S", "COMBO_BIRTHDAY_DELUXE"
  name        String
  description String?
  category    String   // "MUSIC", "SPECIAL_EVENT", "COMBO"
  basePrice   Float
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  metadata    Json     @default("{}") // Extra config like durationSeconds, perSecond, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  venuePrices VenueProductPrice[]
  comboItems  ComboItem[] @relation("ComboProducts")
  inCombos    ComboItem[] @relation("IncludedInCombo")

  @@index([category])
  @@index([code])
  @@index([isActive])
}

model VenueProductPrice {
  id        String  @id @default(uuid())
  venueId   String
  venue     Venue   @relation(fields: [venueId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  price     Float
  isActive  Boolean @default(true)

  @@unique([venueId, productId])
  @@index([venueId])
}

model ComboItem {
  id        String  @id @default(uuid())
  comboId   String
  combo     Product @relation("ComboProducts", fields: [comboId], references: [id])
  productId String
  product   Product @relation("IncludedInCombo", fields: [productId], references: [id])
  quantity  Int     @default(1)

  @@index([comboId])
}

// ============================================
// STAGE 3: REVENUE SPLIT (Multi-Party Commission)
// ============================================
model RevenueSplit {
  id              String   @id @default(uuid())
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id])
  venueId         String
  venue           Venue    @relation(fields: [venueId], references: [id])

  totalAmount     Float
  platformAmount  Float
  platformPercent Float
  venueAmount     Float
  venuePercent    Float
  affiliateAmount Float
  affiliatePercent Float
  operatorAmount  Float
  operatorPercent Float

  affiliateId     String?
  affiliate       User?    @relation("AffiliateSplits", fields: [affiliateId], references: [id])
  operatorId      String?
  operator        User?    @relation("OperatorSplits", fields: [operatorId], references: [id])

  createdAt       DateTime @default(now())

  @@index([transactionId])
  @@index([venueId])
  @@index([affiliateId])
  @@index([operatorId])
  @@index([createdAt(sort: Desc)])
}

// ============================================
// STAGE 3: REGION (Location-Based Catalog)
// ============================================
model Region {
  id        String   @id @default(uuid())
  code      String   @unique  // "SP", "RJ", "MG", "BR-NE"
  name      String            // "São Paulo", "Rio de Janeiro"
  country   String   @default("BR")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  venues         Venue[]
  catalogEntries RegionCatalog[]

  @@index([code])
  @@index([isActive])
}

model RegionCatalog {
  id        String  @id @default(uuid())
  regionId  String
  region    Region  @relation(fields: [regionId], references: [id])
  genreId   String? // If set, entire genre available in region
  genre     Genre?  @relation(fields: [genreId], references: [id])
  artistId  String? // If set, specific artist available
  songId    String? // If set, specific song available
  priority  Int     @default(0) // Higher = shown first

  @@unique([regionId, genreId, artistId, songId])
  @@index([regionId])
}

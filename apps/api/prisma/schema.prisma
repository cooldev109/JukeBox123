generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER
// ============================================
enum UserRole {
  ADMIN
  BAR_OWNER
  CUSTOMER
  EMPLOYEE
  AFFILIATE
}

model User {
  id           String    @id @default(uuid())
  email        String?   @unique
  phone        String?   @unique
  name         String
  role         UserRole  @default(CUSTOMER)
  passwordHash String?
  avatar       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Stage 2 fields
  regionAccess String?   // For EMPLOYEE: city/state/country they manage
  referralCode String?   @unique // For AFFILIATE: unique referral code

  // Relations
  venues              Venue[]              @relation("VenueOwner")
  queueItems          QueueItem[]
  transactions        Transaction[]
  wallet              Wallet?
  playlists           Playlist[]
  songRequests        SongRequest[]
  commissions         Commission[]         @relation("AffiliateCommissions")
  affiliateReferrals  AffiliateReferral[]
  machineAlertsResolved MachineAlert[]     @relation("AlertResolvedBy")
  specialEventsCreated  SpecialEvent[]     @relation("SpecialEventUser")
  specialEventsApproved SpecialEvent[]     @relation("SpecialEventApprover")
  bannersCreated      Banner[]             @relation("BannerCreator")

  @@index([role])
  @@index([email])
  @@index([phone])
  @@index([referralCode])
}

// ============================================
// VENUE (Bar/Club)
// ============================================
enum VenueStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Venue {
  id          String      @id @default(uuid())
  code        String      @unique // Short code for customer entry (e.g. "BAR-CARLOS")
  name        String
  address     String
  city        String
  state       String
  country     String      @default("BR")
  ownerId     String
  timezone    String      @default("America/Sao_Paulo")
  currency    String      @default("BRL")
  settings    Json        @default("{}")
  status      VenueStatus @default(ACTIVE)
  installDate DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  owner              User                @relation("VenueOwner", fields: [ownerId], references: [id])
  machines           Machine[]
  commissions        Commission[]
  affiliateReferrals AffiliateReferral[]

  @@index([ownerId])
  @@index([city, state])
  @@index([status])
}

// ============================================
// MACHINE (Jukebox Device)
// ============================================
enum MachineStatus {
  ONLINE
  OFFLINE
  ERROR
  ALERT
}

model Machine {
  id               String        @id @default(uuid())
  venueId          String
  name             String
  serialNumber     String        @unique
  status           MachineStatus @default(OFFLINE)
  lastHeartbeat    DateTime?
  ipAddress        String?
  offlineSongCache String[]      @default([])
  config           Json          @default("{}")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  venue         Venue          @relation(fields: [venueId], references: [id])
  queueItems    QueueItem[]
  transactions  Transaction[]
  alerts        MachineAlert[]
  specialEvents SpecialEvent[]

  @@index([venueId])
  @@index([status])
  @@index([serialNumber])
}

// ============================================
// SONG
// ============================================
enum SongFormat {
  MP3
  MP4
}

model Song {
  id          String     @id @default(uuid())
  title       String
  artist      String
  album       String?
  genre       String
  duration    Int        // seconds
  fileUrl     String
  videoUrl    String?
  coverArtUrl String?
  metadata    Json       @default("{}")
  fileSize    Int        @default(0) // bytes
  format      SongFormat @default(MP3)
  isActive    Boolean    @default(true)
  playCount   Int        @default(0)
  addedAt     DateTime   @default(now())

  // Relations
  queueItems QueueItem[]

  @@index([title, artist])
  @@index([genre])
  @@index([artist])
  @@index([isActive])
  @@index([playCount(sort: Desc)])
}

// ============================================
// QUEUE
// ============================================
enum QueueItemStatus {
  PENDING
  PLAYING
  PLAYED
  SKIPPED
}

model QueueItem {
  id            String          @id @default(uuid())
  machineId     String
  songId        String
  userId        String
  position      Int
  status        QueueItemStatus @default(PENDING)
  paidAmount    Float           @default(0)
  paymentMethod String          @default("PIX")
  isPriority    Boolean         @default(false)
  createdAt     DateTime        @default(now())
  playedAt      DateTime?

  // Relations
  machine Machine @relation(fields: [machineId], references: [id])
  song    Song    @relation(fields: [songId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([machineId, status])
  @@index([machineId, position])
  @@index([userId])
}

// ============================================
// TRANSACTION
// ============================================
enum TransactionType {
  CREDIT_PURCHASE
  SONG_PAYMENT
  SKIP_QUEUE
  SILENCE
  VOICE_MSG
  REACTION
  PHOTO
  BIRTHDAY_PACK
}

enum PaymentMethod {
  PIX
  WALLET
  CREDIT_CARD
  DEBIT_CARD
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Transaction {
  id               String            @id @default(uuid())
  userId           String
  machineId        String?
  type             TransactionType
  amount           Float
  currency         String            @default("BRL")
  paymentMethod    PaymentMethod
  status           TransactionStatus @default(PENDING)
  pixTransactionId String?
  stripePaymentId  String?           // Stage 2: Stripe payment reference
  idempotencyKey   String?           @unique
  metadata         Json              @default("{}")
  createdAt        DateTime          @default(now())

  // Relations
  user        User         @relation(fields: [userId], references: [id])
  machine     Machine?     @relation(fields: [machineId], references: [id])
  commissions Commission[]

  @@index([userId])
  @@index([machineId])
  @@index([status])
  @@index([type])
  @@index([createdAt(sort: Desc)])
}

// ============================================
// WALLET
// ============================================
model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Float    @default(0)
  currency  String   @default("BRL")
  lastTopUp DateTime?
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ============================================
// PLAYLIST (Customer Saved Playlists)
// ============================================
model Playlist {
  id        String   @id @default(uuid())
  userId    String
  name      String
  songIds   String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ============================================
// SONG REQUEST (Customer requests new songs)
// ============================================
model SongRequest {
  id        String   @id @default(uuid())
  userId    String
  title     String
  artist    String
  notes     String?
  isHandled Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([isHandled])
  @@index([createdAt(sort: Desc)])
}

// ============================================
// GLOBAL CONFIG
// ============================================
model GlobalConfig {
  id    String @id @default(uuid())
  key   String @unique
  value Json

  @@index([key])
}

// ============================================
// STAGE 2: COMMISSION
// ============================================
enum CommissionType {
  SALE
  VENUE_REFERRAL
}

enum CommissionStatus {
  PENDING
  PAID
}

model Commission {
  id                 String           @id @default(uuid())
  affiliateId        String
  transactionId      String
  venueId            String
  percentage         Float
  amount             Float
  type               CommissionType
  status             CommissionStatus @default(PENDING)
  paidAt             DateTime?
  referralDuration   Int?             // months
  referralPercentage Float?
  createdAt          DateTime         @default(now())

  // Relations
  affiliate   User        @relation("AffiliateCommissions", fields: [affiliateId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id])
  venue       Venue       @relation(fields: [venueId], references: [id])

  @@index([affiliateId])
  @@index([transactionId])
  @@index([venueId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

// ============================================
// STAGE 2: AFFILIATE REFERRAL
// ============================================
model AffiliateReferral {
  id               String   @id @default(uuid())
  affiliateId      String
  venueId          String
  referralCode     String
  commissionPercent Float    // 50-100%
  durationMonths   Int      // 1-6
  startDate        DateTime @default(now())
  endDate          DateTime
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  // Relations
  affiliate User  @relation(fields: [affiliateId], references: [id])
  venue     Venue @relation(fields: [venueId], references: [id])

  @@index([affiliateId])
  @@index([venueId])
  @@index([referralCode])
  @@index([isActive])
}

// ============================================
// STAGE 2: MACHINE ALERT
// ============================================
enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertType {
  OFFLINE
  AUDIO_FAIL
  PAYMENT_ERROR
  OWNER_INACTIVE
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  DASHBOARD
}

model MachineAlert {
  id           String              @id @default(uuid())
  machineId    String
  type         AlertType
  message      String
  severity     AlertSeverity       @default(MEDIUM)
  isResolved   Boolean             @default(false)
  resolvedAt   DateTime?
  resolvedById String?
  notifiedVia  NotificationChannel @default(DASHBOARD)
  createdAt    DateTime            @default(now())

  // Relations
  machine    Machine @relation(fields: [machineId], references: [id])
  resolvedBy User?   @relation("AlertResolvedBy", fields: [resolvedById], references: [id])

  @@index([machineId])
  @@index([isResolved])
  @@index([severity])
  @@index([createdAt(sort: Desc)])
}

// ============================================
// STAGE 2: SPECIAL EVENT
// ============================================
enum SpecialEventType {
  SILENCE
  VOICE_MESSAGE
  TEXT_MESSAGE
  PHOTO
  REACTION
  BIRTHDAY
}

enum SpecialEventStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PLAYED
}

model SpecialEvent {
  id           String             @id @default(uuid())
  machineId    String
  userId       String
  type         SpecialEventType
  content      String?            // text content or media URL
  duration     Int?               // seconds
  amount       Float              @default(0)
  status       SpecialEventStatus @default(PENDING_APPROVAL)
  approvedById String?
  createdAt    DateTime           @default(now())

  // Relations
  machine    Machine @relation(fields: [machineId], references: [id])
  user       User    @relation("SpecialEventUser", fields: [userId], references: [id])
  approvedBy User?   @relation("SpecialEventApprover", fields: [approvedById], references: [id])

  @@index([machineId])
  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt(sort: Desc)])
}

// ============================================
// STAGE 2: BANNER
// ============================================
enum BannerTargetRole {
  AFFILIATE
  CUSTOMER
  ALL
}

model Banner {
  id          String           @id @default(uuid())
  targetRole  BannerTargetRole @default(ALL)
  imageUrl    String?
  linkUrl     String?
  message     String
  isActive    Boolean          @default(true)
  startDate   DateTime         @default(now())
  endDate     DateTime?
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  createdBy User @relation("BannerCreator", fields: [createdById], references: [id])

  @@index([targetRole])
  @@index([isActive])
  @@index([startDate, endDate])
}
